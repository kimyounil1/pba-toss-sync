[Unit]
Description=PBA X to Toss Securities auto-sync daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/kimyo/pba-toss-sync
Environment=PYTHONPATH=/home/kimyo/pba-toss-sync
EnvironmentFile=-/home/kimyo/pba-toss-sync/.env
ExecStart=/home/kimyo/pba-toss-sync/scripts/run_daemon.sh
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
