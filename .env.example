# X: 기본은 browser(Playwright 세션). 공식 API만 쓸 때만 설정.
# X_SOURCE=api
# X_SESSION_FILE=${HOME}/.config/pba-toss-sync/x-storage-state.json
X_BEARER_TOKEN=

# LLM (Gemini — optional if using vLLM)
GEMINI_API_KEY=
# GOOGLE_API_KEY=alternative_key

# LLM: local Antigravity CLI (default — not Gemma4 vLLM)
LLM_PROVIDER=agy
LLM_AGY_ENABLED=1
LLM_AGY_BIN=agy
LLM_AGY_WORKDIR=${HOME}/pba-toss-sync
LLM_AGY_MODEL=Gemini 3.5 Flash (Low)
LLM_AGY_TIMEOUT=180

# Optional vLLM / Gemma4 fallback (off by default)
# LLM_VLLM_ENABLED=1
# LLM_VLLM_BASE_URL=http://192.168.219.116:11434/v1
# LLM_VLLM_MODEL=gemma4-26B

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Broker: alpaca paper (default in settings.yaml) or tossctl
PBA_BROKER=alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
PBA_LIVE_TRADING=true
PBA_DRY_RUN=false

# Toss (real account later — not active while broker=alpaca)
TOSSCTL_BIN=${HOME}/.local/bin/tossctl
# TOSSCTL_CONFIG_DIR=config/tossctl  # project-local gates; run scripts/prepare_toss.sh
